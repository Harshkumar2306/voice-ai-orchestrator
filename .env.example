# Environment Variables Configuration
# Copy this file to .env and fill in your keys

# Vapi API Settings
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_ASSISTANT_ID=your_vapi_assistant_id # Optional, we will use dynamic configuration

# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key

# Database Settings
# Using local mongodb for testing: mongodb://mongodb:27017 or your MongoDB Atlas URI
MONGODB_URI=mongodb://localhost:27017
DB_NAME=krid_ai_db

# Backend App Settings
PORT=8000
FRONTEND_URL=http://localhost:5173
# Webhook URL for Vapi (can use ngrok locally or Cloud Run URL in production)
# e.g., https://your-ngrok-url.ngrok-free.app
PUBLIC_URL=http://localhost:8000
